// Format ugly EasyPost service names to customer-friendly display
function formatServiceName(carrier: string, service: string): string {
  let clean = service
    .replace(/^USPS/i, '')
    .replace(/^UPS/i, '')
    .replace(/^FedEx/i, '')
    .replace(/^UPSDAP/i, '')
    .replace(/GreaterThan\d+lb/gi, '')
    .replace(/LessThan\d+lb/gi, '')
    .trim();
  const serviceMap: Record<string, string> = {
    'groundadvantage': 'Ground Advantage',
    'ground': 'Ground',
    'groundsaver': 'Ground Saver',
    'priority': 'Priority Mail',
    'priorityexpress': 'Priority Mail Express',
    'firstclass': 'First Class',
    'parcelselect': 'Parcel Select',
    'express': 'Express',
    '2ndday': '2-Day',
    '2nddayair': '2-Day Air',
    '3dayselect': '3-Day Select',
    'nextdayair': 'Next Day Air',
    'nextdayairsaver': 'Next Day Air Saver',
    'homedelivery': 'Home Delivery',
    'smartpost': 'SmartPost',
  };
  const key = clean.toLowerCase().replace(/[^a-z0-9]/g, '');
  return serviceMap[key] || clean.replace(/([a-z])([A-Z])/g, '$1 $2');
}

// Format carrier names to customer-friendly display
function formatCarrierName(carrier: string): string {
  const carrierMap: Record<string, string> = {
    'upsdap': 'UPS',
    'ups': 'UPS',
    'usps': 'USPS',
    'fedex': 'FedEx',
    'dhl': 'DHL',
  };
  return carrierMap[carrier.toLowerCase()] || carrier;
}

