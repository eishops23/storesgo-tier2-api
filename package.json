{
  "type": "module",
  "name": "storesgo-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prisma:clean": "rimraf node_modules/.prisma && rimraf prisma/generated",
    "prebuild": "npm run prisma:clean",
    "build": "npx prisma generate && rimraf dist && tsc -p tsconfig.build.json && npm run copyjs",
    "copyjs": "node copy-js-files.js",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.build.json",
    "docker:build": "docker build -t storesgo-backend .",
    "docker:run": "docker run -p 5000:5000 --env-file .env storesgo-backend",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:status": "npx prisma migrate status",
    "healthcheck": "curl -f http://localhost:5000/api/health || exit 1",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:logs": "pm2 logs storesgo-api",
    "pm2:monit": "pm2 monit",
    "test:agent": "vitest run src/agent",
    "test:integration": "vitest run src/agent/__integration__ --bail=1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/google": "^3.0.60",
    "@ai-sdk/openai": "^3.0.52",
    "@aws-sdk/client-s3": "^3.948.0",
    "@easypost/api": "^8.4.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^8.3.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^8.55.0",
    "ai": "^6.0.154",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.65.0",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.8.2",
    "jsdom": "^27.2.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^17.0.1",
    "meilisearch": "^0.54.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.8",
    "openai": "^6.9.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.2",
    "redis": "^5.10.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "stripe": "^20.4.0",
    "twilio": "^4.23.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.24",
    "@types/nodemailer": "^6.4.14",
    "prisma": "^5.22.0",
    "rimraf": "^5.0.10",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3"
  }
}
