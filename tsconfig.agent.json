{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "outDir": "./dist/agent",
    "rootDir": "./src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/agent/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.bak*",
    "**/*.backup*",
    "**/*.broken",
    "**/*.deprecated"
  ]
}
