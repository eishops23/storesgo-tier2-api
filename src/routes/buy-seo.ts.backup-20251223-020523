export default async function buySeoRoutes(app: FastifyInstance) {
  
  // Get page data for /buy/[product]/[city]
  app.get("/:product/:city", async (request: FastifyRequest, reply: FastifyReply) => {
    const { product, city } = request.params as { product: string; city: string };
    
    const productData = buyProducts.find(p => p.slug === product);
    const cityData = cities.find(c => c.slug === city);
    
    if (!productData || !cityData) {
      return reply.status(404).send({ ok: false, error: "Not found" });
    }
    
    return reply.send({
      ok: true,
      data: {
        product: productData,
        city: cityData,
        metaTitle: `Buy ${productData.name} in ${cityData.name}, ${cityData.state} | StoresGo`,
        metaDescription: `Find ${productData.name} near you in ${cityData.name}. Order online for delivery or pickup. Authentic ${productData.cuisine[0]} ingredients at great prices.`,
        heroTitle: `Buy ${productData.name} in ${cityData.name}`,
        heroSubtitle: `Get authentic ${productData.name} delivered to your door in ${cityData.name}, ${cityData.state}. Fresh, quality ingredients from local suppliers.`,
        benefits: [
          `Fast delivery to ${cityData.name}`,
          "Quality guaranteed",
          "Best prices on authentic ingredients",
          "Support local ethnic grocery stores"
        ],
        relatedProducts: buyProducts.filter(p => 
          p.cuisine.some(c => productData.cuisine.includes(c)) && p.slug !== product
        ).slice(0, 6),
        nearbyCities: cities.filter(c => c.state === cityData.state && c.slug !== city).slice(0, 4)
      }
    });
  });
  
  // Get all products
  app.get("/products", async (request: FastifyRequest, reply: FastifyReply) => {
    return reply.send({ ok: true, data: buyProducts, total: buyProducts.length });
  });
  
  // Get all cities
  app.get("/cities", async (request: FastifyRequest, reply: FastifyReply) => {
    return reply.send({ ok: true, data: cities, total: cities.length });
  });
  
  // Get sitemap data
  app.get("/sitemap", async (request: FastifyRequest, reply: FastifyReply) => {
    const urls: string[] = [];
    for (const product of buyProducts) {
      for (const city of cities) {
        urls.push(`/buy/${product.slug}/${city.slug}`);
      }
    }
    return reply.send({ ok: true, data: urls, total: urls.length });
  });
  
  // Stats
  app.get("/stats", async (request: FastifyRequest, reply: FastifyReply) => {
    return reply.send({
      ok: true,
      data: {
        products: buyProducts.length,
        cities: cities.length,
        totalPages: buyProducts.length * cities.length
      }
    });
  });
}
