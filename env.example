# =============================================================================
# 🔧 STORESGO BACKEND — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------
NODE_ENV=development                    # development | staging | production
PORT=5000                               # Server port
HOST=0.0.0.0                            # Server host (0.0.0.0 for Docker)
LOG_LEVEL=info                          # debug | info | warn | error

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://storesgo:password@localhost:5432/storesgo_dev"

# Production format (OCI/AWS):
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public&sslmode=require"

# -----------------------------------------------------------------------------
# Redis (BullMQ Queues)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# Production format (with auth):
# REDIS_URL="redis://:password@host:6379"

# -----------------------------------------------------------------------------
# JWT Secrets (generate with: openssl rand -hex 64)
# -----------------------------------------------------------------------------
JWT_SECRET="your-jwt-secret-change-this-in-production"
ADMIN_JWT_SECRET="your-admin-jwt-secret-change-this-in-production"
SELLER_JWT_SECRET="your-seller-jwt-secret-change-this-in-production"

# JWT expiration times
JWT_EXPIRES_IN="7d"
ADMIN_JWT_EXPIRES_IN="24h"
SELLER_JWT_EXPIRES_IN="7d"

# -----------------------------------------------------------------------------
# OpenAI (AI Enrichment & Embeddings)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""                       # sk-xxxx
OPENAI_MODEL="gpt-4o-mini"              # Model for enrichment
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# -----------------------------------------------------------------------------
# Email (Nodemailer)
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false                       # true for 465, false for other ports
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@storesgo.com"

# Alternative: SendGrid
# SENDGRID_API_KEY=""

# -----------------------------------------------------------------------------
# SMS (Twilio)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# -----------------------------------------------------------------------------
# Error Tracking (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=""                           # https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT="development"        # development | staging | production
SENTRY_TRACES_SAMPLE_RATE=0.1           # 0.0 to 1.0 (10% of transactions)

# -----------------------------------------------------------------------------
# Monitoring & Metrics
# -----------------------------------------------------------------------------
METRICS_ENABLED=true                    # Enable Prometheus metrics
METRICS_PORT=9090                       # Separate port for metrics (optional)

# New Relic (alternative APM)
# NEW_RELIC_LICENSE_KEY=""
# NEW_RELIC_APP_NAME="storesgo-backend"

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Shipping API (if using live rates)
SHIPPING_API_KEY=""
SHIPPING_API_URL=""

# Payment Gateway
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Cloud Storage (OCI Object Storage / AWS S3)
# -----------------------------------------------------------------------------
# OCI Object Storage
OCI_NAMESPACE=""
OCI_BUCKET_NAME=""
OCI_REGION=""
OCI_ACCESS_KEY_ID=""
OCI_SECRET_ACCESS_KEY=""

# AWS S3 (alternative)
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET=""

# -----------------------------------------------------------------------------
# Frontend URLs (for email links)
# -----------------------------------------------------------------------------
FRONTEND_URL="https://storesgo.com"     # Main frontend URL
SELLER_DASHBOARD_URL="https://seller.storesgo.com"  # Seller dashboard URL
ADMIN_DASHBOARD_URL="https://admin.storesgo.com"    # Admin dashboard URL

# -----------------------------------------------------------------------------
# CORS & Security
# -----------------------------------------------------------------------------
CORS_ORIGIN="*"                         # Comma-separated list for production
RATE_LIMIT_MAX=100                      # Requests per window
RATE_LIMIT_WINDOW_MS=60000              # 1 minute

# -----------------------------------------------------------------------------
# Password Reset Configuration
# -----------------------------------------------------------------------------
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30  # Token expiry time (default: 30)

# -----------------------------------------------------------------------------
# Cron & Background Jobs
# -----------------------------------------------------------------------------
CRON_ENABLED=true
SEO_CRON_SCHEDULE="0 3 * * *"           # 3 AM daily
CLEANUP_CRON_SCHEDULE="0 4 * * 0"       # 4 AM Sunday

# -----------------------------------------------------------------------------
# AI Blog Posts (Phase 16)
# -----------------------------------------------------------------------------
AUTOBLOG_ENABLED=true                   # Enable/disable autoblog worker
AUTOBLOG_CRON_SCHEDULE="0 0 * * *"      # Daily at midnight (cron expression)
PUBLIC_BASE_URL="https://storesgo.com"  # Base URL for sitemap and links
BLOG_LANGS="en"                         # Comma-separated language codes

# -----------------------------------------------------------------------------
# CAPTCHA Protection (reCAPTCHA v2, v3 or hCaptcha)
# -----------------------------------------------------------------------------
# Provider: "recaptcha" (v2), "recaptcha_v3", or "hcaptcha"
CAPTCHA_PROVIDER="recaptcha_v3"

# Google reCAPTCHA (https://www.google.com/recaptcha/admin)
# v2: Uses checkbox challenge
# v3: Invisible, returns score (0.0-1.0)
RECAPTCHA_SECRET_KEY=""                 # Server-side secret key (v2 or v3)
RECAPTCHA_V3_SCORE_THRESHOLD="0.5"      # Min score for v3 (0.0-1.0, default 0.5)
# Frontend: NEXT_PUBLIC_RECAPTCHA_SITE_KEY="" (add to frontend .env)

# hCaptcha (https://dashboard.hcaptcha.com)
HCAPTCHA_SECRET_KEY=""                  # Server-side secret key
# Frontend: NEXT_PUBLIC_HCAPTCHA_SITE_KEY="" (add to frontend .env)

# CAPTCHA enforcement settings
CAPTCHA_ENABLED=true                    # Master switch to enable/disable CAPTCHA
CAPTCHA_BYPASS_IN_DEV=true              # Skip CAPTCHA verification in development

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------
UPLOAD_DIR="./uploads"                  # Base directory for uploads
UPLOAD_URL_BASE="/uploads"              # Base URL for serving uploads
MAX_UPLOAD_SIZE="10485760"              # Max file size in bytes (10MB)

# S3/Object Storage (if using cloud storage)
# S3_UPLOAD_ENABLED=false
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""                        # Custom endpoint for S3-compatible storage

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_AI_ENRICHMENT=true
FEATURE_NOTIFICATIONS=true
FEATURE_ANALYTICS=true
FEATURE_SEO_GENERATION=true
FEATURE_CAPTCHA=true                    # Enable CAPTCHA on auth endpoints
FEATURE_AUTOBLOG=true                   # Enable AI blog post generation

# -----------------------------------------------------------------------------
# PM2 Configuration
# -----------------------------------------------------------------------------
PM2_INSTANCES="max"                     # Number of instances (max = all CPU cores)

# -----------------------------------------------------------------------------
# Agent Suite — LLM Provider Keys (Phase 0 Part A)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here
GOOGLE_AI_API_KEY=your-google-ai-key-here
