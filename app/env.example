# =============================================================================
# 🔧 STORESGO FRONTEND — ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE="http://localhost:5000"

# -----------------------------------------------------------------------------
# CAPTCHA Configuration (reCAPTCHA or hCaptcha)
# -----------------------------------------------------------------------------
# Provider: "recaptcha" or "hcaptcha" (must match backend CAPTCHA_PROVIDER)
NEXT_PUBLIC_CAPTCHA_PROVIDER="recaptcha"

# Google reCAPTCHA v2 Site Key
# Get yours at: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# hCaptcha Site Key (alternative to reCAPTCHA)
# Get yours at: https://dashboard.hcaptcha.com
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""

