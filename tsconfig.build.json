{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/index.prod.ts",
    "src/server.ts",
    "src/routes/**/*",
    "src/core/**/*",
    "src/controllers/**/*",
    "src/services/**/*",
    "src/plugins/prisma.ts",
    "src/plugins/adminJwt.ts",
    "src/plugins/sellerJwt.ts",
    "src/plugins/rateLimit.ts",
    "src/plugins/sentry.ts",
    "src/plugins/metrics.ts",
    "src/schemas/**/*",
    "src/lib/prisma.ts",
    "src/lib/search.ts",
    "src/middleware/**/*",
    "src/utils/**/*",
    "src/types/**/*",
    "src/cron/maintenance.cron.ts"
  ],
  "exclude": [
    "src/ai",
    "src/cron/orchestrator.ts",
    "src/cron/seo.cron.ts",
    "src/cron/seoReportCron.ts",
    "src/cron/internalLinkCron.ts",
    "src/jobs",
    "src/queues",
    "src/workers",
    "src/plugins/queues.ts",
    "src/plugins/redis.ts",
    "src/plugins/websocket.ts",
    "src/plugins/monitoring.ts",
    "src/scripts",
    "src/archive",
    "src/smoke",
    "src/lib/queues.ts",
    "src/lib/semanticSearch.ts",
    "src/lib/translate.ts",
    "src/lib/voice.ts",
    "src/services/notificationService.ts",
    "node_modules",
    "dist"
  ]
}
