// Get coordinates for a ZIP code
function getZipCoords(zip: string): [number, number] {
  const prefix3 = zip.substring(0, 3);
  if (ZIP_COORDS[prefix3]) return ZIP_COORDS[prefix3];
  
  // Fallback: estimate based on first digit (rough US region)
  const firstDigit = zip.charAt(0);
  const fallbacks: Record<string, [number, number]> = {
    "0": [42.36, -71.06],   // Northeast
    "1": [40.71, -74.01],   // NY/NJ
    "2": [38.91, -77.04],   // Mid-Atlantic
    "3": [33.75, -84.39],   // Southeast
    "4": [41.88, -87.63],   // Midwest
    "5": [44.98, -93.27],   // Upper Midwest
    "6": [41.88, -87.63],   // Central
    "7": [29.76, -95.37],   // South Central
    "8": [39.74, -104.99],  // Mountain
    "9": [34.05, -118.24],  // West Coast
  };
  return fallbacks[firstDigit] || [39.50, -98.35]; // Geographic center of US
}

// Get distance between ZIP codes in miles
function getDistanceFromZip(zip1: string, zip2: string): number {
  const c1 = getZipCoords(zip1);
  const c2 = getZipCoords(zip2);
  const R = 3959; // Earth radius in miles
  const dLat = (c2[0] - c1[0]) * Math.PI / 180;
  const dLon = (c2[1] - c1[1]) * Math.PI / 180;
  const a = Math.sin(dLat/2)**2 + Math.cos(c1[0]*Math.PI/180)*Math.cos(c2[0]*Math.PI/180)*Math.sin(dLon/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

// Get seller's ZIP code from database
async function getSellerZip(sellerId: number): Promise<string | null> {
  try {
    const seller = await prisma.seller.findUnique({
      where: { id: sellerId },
      select: { zipCode: true, city: true, state: true }
    });
    return seller?.zipCode || null;
  } catch {
    return null;
  }
}

// Get live rates from EasyPost
async function getEasyPostRates(fromZip: string, toZip: string, weight: number, fromCity?: string, fromState?: string): Promise<ShippingOption[]> {
  if (!EASYPOST_API_KEY) return [];

  try {
    const EasyPost = (await import("@easypost/api")).default;
    const client = new EasyPost(EASYPOST_API_KEY);

    const shipment = await client.Shipment.create({
      from_address: { 
        street1: "100 Main St", 
        city: fromCity || "Miami", 
        state: fromState || "FL", 
        zip: fromZip, 
        country: "US" 
      },
      to_address: { 
        street1: "123 Customer St", 
        city: "Customer City", 
        state: "FL", 
        zip: toZip, 
        country: "US" 
      },
      parcel: { weight: weight * 16, length: 10, width: 8, height: 4 }
    });

    return shipment.rates.map((rate: any) => ({
      id: rate.id,
      carrier: formatCarrierName(rate.carrier),
      service: formatServiceName(rate.carrier, rate.service),
      days: rate.delivery_days ? `${rate.delivery_days} day${rate.delivery_days > 1 ? 's' : ''}` : "2-5 days",
      price: Math.round(parseFloat(rate.rate) * 100),
      deliveryDate: rate.delivery_date
    }));
  } catch (error: any) {
    console.error("EasyPost error:", error.message);
    return [];
  }
}

// Generate estimated rates when API unavailable
function generateEstimatedRates(distance: number, weight: number): ShippingOption[] {
  return [
    { id: "usps-ground", carrier: "USPS", service: "Ground Advantage", days: "2-5 days", price: Math.round((5.95 + weight*0.35 + distance*0.002)*100) },
    { id: "usps-priority", carrier: "USPS", service: "Priority Mail", days: distance > 500 ? "2-3 days" : "1-3 days", price: Math.round((8.95 + weight*0.5 + distance*0.002)*100) },
    { id: "fedex-ground", carrier: "FedEx", service: "Ground", days: distance > 500 ? "3-5 days" : "1-3 days", price: Math.round((9.50 + weight*0.45 + distance*0.003)*100) },
    { id: "ups-ground", carrier: "UPS", service: "Ground", days: distance > 500 ? "3-5 days" : "1-3 days", price: Math.round((10.25 + weight*0.48 + distance*0.0035)*100) },
  ];
}

// Check cold products
async function checkColdProducts(productIds: number[]): Promise<{ hasCold: boolean; coldProducts: any[] }> {
  if (!productIds.length) return { hasCold: false, coldProducts: [] };
  const validIds = productIds.filter(id => !isNaN(id) && id > 0);
  if (!validIds.length) return { hasCold: false, coldProducts: [] };
  
  // Cold/Refrigerated category IDs
  const coldCategoryIds = [
    // Fresh Milk & Dairy Beverages
    2687, 2688, 2689, 2690, 2691, 2892, 2897, 2898, 2899, 2900, 2901, 2902, 2903, 2904,
    // Dairy & Eggs base
    2868, 2895,
    // Cheese
    2872, 2873, 2874, 2877, 2878, 2882, 2887, 2888, 2915, 2917, 2918,
    // Cream, Butter, Creamer
    2869, 2889, 2890, 2891, 2893, 2894, 2905, 2906, 2907,
    // Yogurt
    2908, 2909, 2910, 2911, 2912, 2913, 3400,
    // Deli
    2914, 2919, 2921, 2923, 2926, 2928, 2929,
    // Fresh Meat & Seafood (3138-3172)
    3138, 3139, 3140, 3141, 3144, 3145, 3146, 3147, 3148, 3149,
    3150, 3151, 3154, 3155, 3156, 3157, 3158, 3159, 3160, 3161, 3162, 3163, 3164, 3166, 3167, 3168, 3169, 3170, 3171, 3172,
    // Breakfast Sausage
    2991,
    // Frozen categories
    2591, 2592, 2593, 2981, 2982, 2985, 2988, 2993, 2996, 2997, 3000, 3005,
    // Frozen Meat & Seafood
    3008, 3009, 3010, 3011, 3012, 3013, 3014, 3015,
    // More frozen
    3016, 3022, 3310, 3311, 3369, 3371, 3398, 3399,
    // Tofu (refrigerated)
    2935
  ];
  
  try {
    const coldProducts = await prisma.$queryRawUnsafe<any[]>(`
      SELECT DISTINCT p.id, p.name FROM products p
      WHERE p.id IN (${validIds.join(",")})
      AND (
        -- Primary: Category-based detection (most reliable)
        p.category_id IN (${coldCategoryIds.join(",")})
        OR
        -- Fallback: Keyword-based detection
        (
          (
            p.name ILIKE '%frozen%' OR p.name ILIKE '%ice cream%' OR p.name ILIKE '%gelato%'
            OR p.name ILIKE '%yogurt%' OR p.name ILIKE '%yoghurt%' OR p.name ILIKE '%kefir%'
            OR p.name ILIKE '%fresh milk%' OR p.name ILIKE '%whole milk%' OR p.name ILIKE '%2% milk%' OR p.name ILIKE '%skim milk%'
            OR p.name ILIKE '%cottage cheese%' OR p.name ILIKE '%cream cheese%' OR p.name ILIKE '%sour cream%'
            OR p.name ILIKE '%butter %' OR p.name ILIKE '% butter' OR p.name ILIKE '%margarine%'
            OR p.name ILIKE '%fresh meat%' OR p.name ILIKE '%raw chicken%' OR p.name ILIKE '%ground beef%'
            OR p.name ILIKE '%fresh fish%' OR p.name ILIKE '%fresh salmon%' OR p.name ILIKE '%fresh shrimp%'
            OR p.name ILIKE '%deli meat%' OR p.name ILIKE '%sliced turkey%' OR p.name ILIKE '%sliced ham%'
            OR p.name ILIKE '%heavy cream%' OR p.name ILIKE '%whipping cream%' OR p.name ILIKE '%half and half%'
            OR p.name ILIKE '%egg %' OR p.name ILIKE '% eggs' OR p.name ILIKE '%dozen eggs%'
            OR p.name ILIKE '%tofu%' OR p.name ILIKE '%tempeh%'
          )
          -- Exclude shelf-stable items
          AND NOT (
            p.name ILIKE '%shelf stable%' OR p.name ILIKE '%shelf-stable%'
            OR p.name ILIKE '%powdered%' OR p.name ILIKE '%dried%' OR p.name ILIKE '%dry %'
            OR p.name ILIKE '%canned%' OR p.name ILIKE '%evaporated%' OR p.name ILIKE '%condensed%'
            OR p.name ILIKE '%egg noodle%' OR p.name ILIKE '%egg roll wrapper%'
            OR p.name ILIKE '%peanut butter%' OR p.name ILIKE '%almond butter%' OR p.name ILIKE '%sunflower butter%'
            OR p.name ILIKE '%cocoa butter%' OR p.name ILIKE '%shea butter%'
          )
        )
      )
    `);
    return { hasCold: coldProducts.length > 0, coldProducts };
  } catch (e) { 
    console.error("Cold check error:", e);
    return { hasCold: false, coldProducts: [] }; 
  }
}

// Main shipping calculation - FULLY DYNAMIC
export async function calculateShippingOptions(params: {
  buyerZip: string;
  sellerIds?: number[];
  productIds?: number[];
  totalWeight?: number;
  sellerId?: number; // Single seller for direct lookup
}): Promise<{
  options: ShippingOption[];
  distance: number;
  hasCold: boolean;
  coldRestriction: boolean;
  coldProducts: any[];
  localDeliveryAvailable: boolean;
}> {
  const { buyerZip, productIds = [], totalWeight = 2, sellerId, sellerIds } = params;
  
  // Get seller ZIP dynamically
  const effectiveSellerId = sellerId || (sellerIds && sellerIds[0]) || 1;
  const sellerData = await prisma.seller.findUnique({
    where: { id: effectiveSellerId },
    select: { zipCode: true, city: true, state: true }
  });
  
  const sellerZip = sellerData?.zipCode || "33101"; // Fallback only if seller has no ZIP
  const sellerCity = sellerData?.city || "Miami";
  const sellerState = sellerData?.state || "FL";
  
  const distance = Math.round(getDistanceFromZip(sellerZip, buyerZip));

  const { hasCold, coldProducts } = await checkColdProducts(productIds);
  const coldRestriction = hasCold && distance > 50;
  
  // Local delivery ONLY if within 25 miles
  const localDeliveryAvailable = distance <= 25;

  // Try live rates first
  let carrierOptions = await getEasyPostRates(sellerZip, buyerZip, totalWeight, sellerCity, sellerState);

  // Fallback to estimates
  if (carrierOptions.length === 0) {
    carrierOptions = generateEstimatedRates(distance, totalWeight);
  }

  // Sort by price, take top 4
  carrierOptions = carrierOptions.sort((a, b) => a.price - b.price).slice(0, 4);

  // Add local delivery ONLY if seller is within 25 miles of buyer
  const localOptions: ShippingOption[] = [];
  if (localDeliveryAvailable) {
    localOptions.push({ 
      id: "local-same", 
      carrier: "Local", 
      service: "Same Day Delivery", 
      days: "Today", 
      price: distance < 10 ? 499 : 699, 
      isLocal: true 
    });
    localOptions.push({ 
      id: "local-next", 
      carrier: "Local", 
      service: "Next Day Delivery", 
      days: "Tomorrow", 
      price: distance < 10 ? 299 : 399, 
      isLocal: true 
    });
  }

  let finalOptions = [...localOptions, ...carrierOptions];

  // Restrict slow shipping for cold products
  if (coldRestriction) {
    finalOptions = finalOptions.filter(o => o.isLocal || o.days.includes("1") || o.days.includes("2") || o.service.includes("Express"));
  }

  return { options: finalOptions, distance, hasCold, coldRestriction, coldProducts, localDeliveryAvailable };
}

export async function getColdProductsInCart(productIds: number[]): Promise<any[]> {
  const { coldProducts } = await checkColdProducts(productIds);
  return coldProducts;
}

