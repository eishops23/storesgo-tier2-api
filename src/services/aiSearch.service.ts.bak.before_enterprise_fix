export async function getFrequentlyBoughtTogether(productId: number, limit = 6) {
  try {
    const result = await productsIndex.search("", { filter: `id = ${productId}`, limit: 1 });
    if (!result.hits.length) return [];
    const p = result.hits[0] as any;
    const similar = await productsIndex.search("", { filter: `categoryId = ${p.categoryId} AND id != ${productId}`, limit });
    return similar.hits;
  } catch { return []; }
}

const recentlyViewedMap = new Map<string, number[]>();

export async function trackProductView(sessionId: string, productId: number, userId?: number) {
  const views = recentlyViewedMap.get(sessionId) || [];
  recentlyViewedMap.set(sessionId, [productId, ...views.filter(id => id !== productId)].slice(0, 20));
}

export async function getRecentlyViewed(sessionId: string, limit = 10) {
  const ids = recentlyViewedMap.get(sessionId) || [];
  if (!ids.length) return [];
  try {
    return (await productsIndex.search("", { filter: ids.map(id => `id = ${id}`).join(" OR "), limit })).hits;
  } catch { return []; }
}

